# StanleySync Suite environment example
# Copy app-specific values into apps/quoteflow/.env.local for local development,
# or configure these variables in the cloud host.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="https://your-stanleysync-demo.example.com"
APP_BASE_URL="https://your-stanleysync-demo.example.com"
DEMO_MODE="true"
PILOT_MODE="true"
ENABLE_LABS_MODULE="false"
ENABLE_PUBLIC_SIGNUP="false"

ADMIN_EMAIL="masonstanley@stanleysync.com"
# Prefer ADMIN_PASSWORD_HASH in production.
ADMIN_PASSWORD=""
ADMIN_PASSWORD_HASH=""

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"

ADMIN_NOTIFICATION_EMAIL="ops@example.com"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="StanleySync <noreply@example.com>"
