# StanleySync App environment example.
# Configure these values in the hosted provider for web demos.
# Keep secrets out of source control.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="https://demo.stanleysync.app"
APP_BASE_URL="https://demo.stanleysync.app"

# Hosted demo flags
DEMO_MODE="true"
PILOT_MODE="true"
ENABLE_LABS_MODULE="false"
ENABLE_PUBLIC_SIGNUP="false"

# Admin login
ADMIN_EMAIL="masonstanley@stanleysync.com"
# Prefer ADMIN_PASSWORD_HASH for hosted environments.
ADMIN_PASSWORD=""
ADMIN_PASSWORD_HASH=""

# OpenAI / server-side AI only
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"

# Email notifications
ADMIN_NOTIFICATION_EMAIL="ops@example.com"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# SMTP_PASSWORD="" # Optional legacy alias. SMTP_PASS is preferred.
EMAIL_FROM="StanleySync App <noreply@stanleysync.app>"
